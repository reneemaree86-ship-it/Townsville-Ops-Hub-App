{
  "name": "AgentRun",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string",
      "description": "Reference to Business"
    },
    "run_type": {
      "type": "string",
      "description": "Type of agent run"
    },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed"],
      "default": "running",
      "description": "Agent run status"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Run start timestamp"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Run completion timestamp"
    },
    "summary": {
      "type": "string",
      "description": "Summary of the agent run"
    },
    "error": {
      "type": "string",
      "description": "Error message if run failed"
    }
  },
  "required": [],
  "rls": {
    "create": { "created_by_id": "{{user.id}}" },
    "read": {
      "$or": [
        { "created_by_id": "{{user.id}}" },
        { "user_condition": { "role": "admin" } }
      ]
    },
    "update": {
      "$or": [
        { "created_by_id": "{{user.id}}" },
        { "user_condition": { "role": "admin" } }
      ]
    },
    "delete": {
      "$or": [
        { "created_by_id": "{{user.id}}" },
        { "user_condition": { "role": "admin" } }
      ]
    }
  }
}
