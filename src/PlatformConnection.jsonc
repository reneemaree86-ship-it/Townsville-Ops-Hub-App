{
  "name": "PlatformConnection",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "enum": [
        "facebook",
        "google",
        "gumtree",
        "airtasker",
        "townsville_noticeboard",
        "instagram",
        "stripe",
        "google_sheets",
        "google_search_console",
        "gmail",
        "github",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "connected",
        "disconnected",
        "error",
        "pending"
      ]
    },
    "last_checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_successful_at": {
      "type": "string",
      "format": "date-time"
    },
    "error_message": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "account_label": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": []
}
